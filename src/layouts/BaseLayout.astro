---
import Navigation from "../components/Navigation.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";

interface Props {
	title: string;
	bgPattern?: "grid" | "dots" | "diagonal";
	wide?: boolean;
}

const { title, bgPattern, wide } = Astro.props;
const bgClass = bgPattern ? `bg-${bgPattern}` : undefined;
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
		<link rel="icon" href={`${import.meta.env.BASE_URL}favicon.ico`} sizes="any" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body class:list={["flex min-h-screen flex-col bg-page font-mono text-ink", bgClass]}>
		<Navigation />
		<main class:list={["mx-auto w-full flex-1 px-4 py-8", wide ? "max-w-6xl" : "max-w-4xl"]}>
			<slot />
		</main>
		<Footer />
	</body>
</html>
