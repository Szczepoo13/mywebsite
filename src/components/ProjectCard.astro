---
interface Props {
	title: string;
	description: string;
	tags: string[];
	repo?: string;
	url?: string;
}

const { title, description, tags, repo, url } = Astro.props;
---

<div class="border border-neutral-300 px-5 py-4">
	<h2 class="text-base font-semibold tracking-tight">{title}</h2>
	<p class="mt-2 text-sm text-neutral-600">{description}</p>
	{
		tags.length > 0 && (
			<ul class="mt-3 flex flex-wrap gap-2 text-xs text-neutral-500">
				{tags.map((tag) => (
					<li class="border border-neutral-300 px-2 py-0.5">{tag}</li>
				))}
			</ul>
		)
	}
	{
		(repo || url) && (
			<div class="mt-3 flex gap-4 text-xs">
				{repo && (
					<a href={repo} class="text-blue-700 hover:underline" target="_blank" rel="noreferrer">
						Repo
					</a>
				)}
				{url && (
					<a href={url} class="text-blue-700 hover:underline" target="_blank" rel="noreferrer">
						Live
					</a>
				)}
			</div>
		)
	}
</div>
