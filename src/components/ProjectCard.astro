---
import Badge from "./Badge.astro";

interface Props {
	title: string;
	description: string;
	tags: string[];
	repo?: string;
	url?: string;
}

const { title, description, tags, repo, url } = Astro.props;
---

<div class="panel-raised px-5 py-4">
	<h2 class="text-base font-bold tracking-tight">{title}</h2>
	<p class="mt-2 text-sm">{description}</p>
	{
		tags.length > 0 && (
			<ul class="mt-3 flex flex-wrap gap-2">
				{tags.map((tag) => (
					<li>
						<Badge label={tag} />
					</li>
				))}
			</ul>
		)
	}
	{
		(repo || url) && (
			<div class="mt-3 flex gap-2 text-xs">
				{repo && (
					<a
						href={repo}
						class="panel-raised px-2 py-0.5 hover:[border-style:inset]"
						target="_blank"
						rel="noreferrer"
					>
						Repo
					</a>
				)}
				{url && (
					<a
						href={url}
						class="panel-raised px-2 py-0.5 hover:[border-style:inset]"
						target="_blank"
						rel="noreferrer"
					>
						Live
					</a>
				)}
			</div>
		)
	}
</div>
