---
interface Props {
	title: string;
	authors: string;
	venue: string;
	date: Date;
	url?: string;
}

const { title, authors, venue, date, url } = Astro.props;
---

<div class="panel-raised px-5 py-4">
	<h2 class="text-base font-bold tracking-tight">
		{
			url ? (
				<a href={url} class="text-link hover:underline" target="_blank" rel="noreferrer">
					{title}
				</a>
			) : (
				title
			)
		}
	</h2>
	<p class="mt-1 text-sm">{authors}</p>
	<p class="mt-1 text-xs">{venue} · {date.getFullYear()}</p>
</div>
