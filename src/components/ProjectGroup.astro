---
import Badge from "./Badge.astro";

interface GroupedProject {
	slug: string;
	title: string;
	description: string;
	tags: string[];
	repo?: string;
}

interface Props {
	kicker?: string;
	title: string;
	titleUrl?: string;
	projects: GroupedProject[];
}

const { kicker, title, titleUrl, projects } = Astro.props;

// Every card is a fixed width and shares a minimum height so cards look
// identical across boxes, no matter how many projects are in a given
// group. Cards that share a row auto-stretch to match each other's height,
// but a card alone in its own box (nothing to stretch against) would
// otherwise size to its own shorter content, hence the explicit min-height.
const CARD_SIZE = "w-[328px] min-h-[352px]";
// A two-card box is capped to exactly fit its cards side by side instead of
// stretching full-width with empty space (computed, not `w-fit`, since
// `fit-content` sizing also factors in the box's own title text, which
// blows the width back out for long research-paper titles). A one-card box
// instead grows to fill whatever room is left in its row, so it still lines
// up with the wider boxes instead of leaving a gap next to them.
const CARD_PX = 328;
const GAP_PX = 16;
const PAD_PX = 48; // px-6 on both sides
const BORDER_PX = 4; // .card's own 2px border, both sides
const boxWidthPx = projects.length * CARD_PX + (projects.length - 1) * GAP_PX + PAD_PX + BORDER_PX;
const boxStyle = projects.length === 2 ? { width: `${boxWidthPx}px` } : undefined;
const growContent = projects.length === 1;
---

<div class:list={["card border-t-4 border-t-gold px-6 py-6", growContent && "flex-1"]} style={boxStyle}>
	{kicker && <p class="text-xs font-bold tracking-wide text-gold uppercase">{kicker}</p>}
	<h2 class:list={["text-base font-bold tracking-tight", kicker && "mt-1"]}>
		{
			titleUrl ? (
				<a href={titleUrl} target="_blank" rel="noreferrer" class="hover:underline">
					{title}
				</a>
			) : (
				title
			)
		}
	</h2>
	<div class="mt-4 flex flex-wrap gap-4">
		{
			projects.map((project) => (
				<div class:list={["card-3d px-4 py-4", CARD_SIZE]}>
					<h3 class="text-sm font-bold">{project.title}</h3>
					<p class="mt-2 text-xs text-muted">{project.description}</p>
					{project.tags.length > 0 && (
						<ul class="mt-3 flex flex-wrap gap-2">
							{project.tags.map((tag) => (
								<li>
									<Badge label={tag} />
								</li>
							))}
						</ul>
					)}
					<div class="mt-3 flex gap-2 text-xs">
						<a
							href={`${import.meta.env.BASE_URL}projects/${project.slug}/`}
							class="btn-blue btn-3d px-3 py-1 font-semibold"
						>
							&lt;expand&gt;
						</a>
						{project.repo && (
							<a
								href={project.repo}
								class="btn-blue btn-3d px-3 py-1 font-semibold"
								target="_blank"
								rel="noreferrer"
							>
								Repo
							</a>
						)}
					</div>
				</div>
			))
		}
	</div>
</div>
