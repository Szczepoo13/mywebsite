---
import Badge from "./Badge.astro";

interface GroupedProject {
	slug: string;
	title: string;
	description: string;
	tags: string[];
	repo?: string;
}

interface Props {
	kicker?: string;
	title: string;
	titleUrl?: string;
	projects: GroupedProject[];
}

const { kicker, title, titleUrl, projects } = Astro.props;

// A box only holds as many grid columns as it has projects, so a
// one- or two-project group doesn't stretch full-width with empty space.
const widthClass = projects.length === 1 ? "max-w-sm" : projects.length === 2 ? "max-w-2xl" : "";
const gridColsClass =
	projects.length === 1 ? "" : projects.length === 2 ? "sm:grid-cols-2" : "sm:grid-cols-2 xl:grid-cols-3";
---

<div class:list={["card border-t-4 border-t-gold px-6 py-6", widthClass]}>
	{kicker && <p class="text-xs font-bold tracking-wide text-gold uppercase">{kicker}</p>}
	<h2 class:list={["text-base font-bold tracking-tight", kicker && "mt-1"]}>
		{
			titleUrl ? (
				<a href={titleUrl} target="_blank" rel="noreferrer" class="hover:underline">
					{title}
				</a>
			) : (
				title
			)
		}
	</h2>
	<div class:list={["mt-4 grid gap-4", gridColsClass]}>
		{
			projects.map((project) => (
				<div class="card-3d px-4 py-4">
					<h3 class="text-sm font-bold">{project.title}</h3>
					<p class="mt-2 text-xs text-muted">{project.description}</p>
					{project.tags.length > 0 && (
						<ul class="mt-3 flex flex-wrap gap-2">
							{project.tags.map((tag) => (
								<li>
									<Badge label={tag} />
								</li>
							))}
						</ul>
					)}
					<div class="mt-3 flex gap-2 text-xs">
						<a
							href={`${import.meta.env.BASE_URL}projects/${project.slug}/`}
							class="btn-blue px-3 py-1 font-semibold"
						>
							&lt;expand&gt;
						</a>
						{project.repo && (
							<a
								href={project.repo}
								class="btn-blue px-3 py-1 font-semibold"
								target="_blank"
								rel="noreferrer"
							>
								Repo
							</a>
						)}
					</div>
				</div>
			))
		}
	</div>
</div>
