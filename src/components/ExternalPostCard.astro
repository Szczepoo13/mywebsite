---
interface Props {
	title: string;
	description: string;
	date: Date;
	externalUrl: string;
}

const { title, description, date, externalUrl } = Astro.props;
---

<details class="card-3d px-5 py-4">
	<summary class="cursor-pointer text-sm">
		<span class="text-base font-bold tracking-tight">{title}</span>
		<span class="mt-1 block text-xs text-muted">{date.toISOString().slice(0, 10)}</span>
	</summary>
	<p class="mt-3 text-sm text-muted">{description}</p>
	<a
		href={externalUrl}
		class="btn-blue mt-3 inline-block px-3 py-1 text-xs font-semibold"
		target="_blank"
		rel="noreferrer"
	>
		Read on Nextrope →
	</a>
</details>
