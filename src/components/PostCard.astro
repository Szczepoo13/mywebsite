---
interface Props {
	slug: string;
	title: string;
	description: string;
	date: Date;
}

const { slug, title, description, date } = Astro.props;
---

<a href={`/blog/${slug}/`} class="card block px-5 py-4 transition-colors hover:border-accent-blue">
	<h2 class="text-base font-bold tracking-tight">{title}</h2>
	<time datetime={date.toISOString()} class="mt-1 block text-xs text-muted">
		{date.toISOString().slice(0, 10)}
	</time>
	<p class="mt-2 text-sm text-muted">{description}</p>
</a>
