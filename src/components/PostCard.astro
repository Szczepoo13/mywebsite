---
interface Props {
	slug: string;
	title: string;
	description: string;
	date: Date;
}

const { slug, title, description, date } = Astro.props;
---

<a href={`/blog/${slug}/`} class="block border border-neutral-300 px-5 py-4 hover:border-blue-700">
	<div class="flex items-baseline justify-between gap-4">
		<h2 class="text-base font-semibold tracking-tight">{title}</h2>
		<time datetime={date.toISOString()} class="shrink-0 text-xs text-neutral-500">
			{date.toISOString().slice(0, 10)}
		</time>
	</div>
	<p class="mt-2 text-sm text-neutral-600">{description}</p>
</a>
