---
interface Props {
	slug: string;
	title: string;
	description: string;
	date: Date;
}

const { slug, title, description, date } = Astro.props;
---

<a href={`/blog/${slug}/`} class="panel-raised block px-5 py-4 hover:[border-style:inset]">
	<div class="flex items-baseline justify-between gap-4">
		<h2 class="text-base font-bold tracking-tight">{title}</h2>
		<time datetime={date.toISOString()} class="shrink-0 text-xs">
			{date.toISOString().slice(0, 10)}
		</time>
	</div>
	<p class="mt-2 text-sm">{description}</p>
</a>
