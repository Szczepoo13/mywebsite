---
const links = [
	{ href: "/blog/", label: "Blog" },
	{ href: "/projects/", label: "Projects" },
];
---

<header class="panel-sunken">
	<nav class="mx-auto flex max-w-4xl flex-wrap items-center justify-between gap-4 px-4 py-3">
		<a href="/" class="font-mono text-sm font-bold tracking-tight text-ink">SZCZEPAN GURGUL</a>
		<ul class="flex flex-wrap items-center gap-5 text-sm">
			{
				links.map((link) => (
					<li>
						<a href={link.href} class="text-link hover:underline">
							{link.label}
						</a>
					</li>
				))
			}
		</ul>
	</nav>
</header>
