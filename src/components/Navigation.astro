---
const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;
const isHome = currentPath === base;

const navLinks = [
	{ href: `${base}projects/`, label: "Projects" },
	{ href: `${base}blog/`, label: "Blog" },
];
const socialLinks = [
	{ href: "https://github.com/Szczepoo13", label: "GitHub" },
	{ href: "https://www.linkedin.com/in/szczepan-gurgul-aaa106215", label: "LinkedIn" },
];
---

<header class="bar border-b-2 border-border">
	<nav class="mx-auto flex max-w-4xl items-stretch justify-between px-4">
		<a href={base} class="block py-3 leading-tight">
			<span class="font-mono text-sm font-bold tracking-tight text-ink">SZCZEPAN GURGUL</span>
			<span class:list={["block text-xs", isHome ? "font-semibold text-gold" : "text-muted"]}>
				[home]
			</span>
		</a>
		<div class="flex items-stretch">
			<ul class="flex text-sm">
				{
					navLinks.map((link) => (
						<li class="flex">
							<a
								href={link.href}
								class:list={[
									"flex items-center px-4 font-semibold",
									currentPath.startsWith(link.href) ? "btn-gold" : "btn-blue",
								]}
							>
								{link.label}
							</a>
						</li>
					))
				}
			</ul>
			<ul class="ml-4 flex list-none items-center gap-4 self-center text-sm">
				{
					socialLinks.map((link) => (
						<li>
							<a
								href={link.href}
								class="text-accent-blue hover:underline"
								target="_blank"
								rel="noreferrer"
							>
								{link.label}
							</a>
						</li>
					))
				}
			</ul>
		</div>
	</nav>
</header>
