---
const links = [
	{ href: "/projects/", label: "Projects" },
	{ href: "/blog/", label: "Blog" },
];
---

<header class="bar border-b border-border">
	<nav class="mx-auto flex max-w-4xl flex-wrap items-center justify-between gap-4 px-4 py-3">
		<a href="/" class="block leading-tight">
			<span class="font-mono text-sm font-bold tracking-tight text-ink">SZCZEPAN GURGUL</span>
			<span class="block text-xs text-muted">[home]</span>
		</a>
		<ul class="flex flex-wrap items-center gap-2 text-sm">
			{
				links.map((link) => (
					<li>
						<a href={link.href} class="btn-blue block px-3 py-1 font-semibold">
							{link.label}
						</a>
					</li>
				))
			}
		</ul>
	</nav>
</header>
