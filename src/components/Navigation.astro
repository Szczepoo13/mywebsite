---
const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;
const isHome = currentPath === base;

const navLinks = [
	{ href: `${base}projects/`, label: "Projects" },
	{ href: `${base}blog/`, label: "Blog" },
	{ href: `${base}contact/`, label: "Contact" },
];
const socialLinks = [
	{ href: "https://github.com/Szczepoo13", label: "GitHub" },
	{ href: "https://www.linkedin.com/in/szczepan-gurgul-aaa106215", label: "LinkedIn" },
];
---

<header class="bar border-b-2 border-border">
	<nav class="mx-auto flex max-w-4xl flex-wrap items-center justify-between gap-x-4 gap-y-2 px-4 py-2">
		<a href={base} class="btn-press block leading-tight">
			<span class="font-mono text-sm font-bold tracking-tight text-ink">SZCZEPAN GURGUL</span>
			<span class:list={["block text-xs", isHome ? "font-semibold text-gold" : "text-muted"]}>
				[home]
			</span>
		</a>
		<div class="flex flex-wrap items-center gap-2">
			<ul class="flex flex-wrap text-sm">
				{
					navLinks.map((link) => (
						<li class="flex">
							<a
								href={link.href}
								class:list={[
									"flex items-center px-4 py-1 font-semibold btn-press",
									currentPath.startsWith(link.href) ? "btn-blue-active" : "btn-blue",
								]}
							>
								{link.label}
							</a>
						</li>
					))
				}
			</ul>
			<ul class="flex list-none flex-wrap items-center gap-4 text-sm">
				{
					socialLinks.map((link) => (
						<li>
							<a
								href={link.href}
								class="text-accent-blue underline"
								target="_blank"
								rel="noreferrer"
							>
								{link.label}
							</a>
						</li>
					))
				}
			</ul>
		</div>
	</nav>
</header>
