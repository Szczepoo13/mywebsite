---
const currentPath = Astro.url.pathname;
const links = [
	{ href: "/blog/", label: "Blog" },
	{ href: "/projects/", label: "Projects" },
];
---

<header class="bar border-b border-border">
	<nav class="mx-auto flex max-w-4xl flex-wrap items-center justify-between gap-4 px-4 py-3">
		<a href="/" class="font-mono text-sm font-bold tracking-tight text-ink">SZCZEPAN GURGUL</a>
		<ul class="flex flex-wrap items-center gap-2 text-sm">
			{
				links.map((link) => (
					<li>
						<a
							href={link.href}
							class={
								currentPath.startsWith(link.href)
									? "btn-blue block px-3 py-1 font-semibold"
									: "block px-3 py-1 text-muted hover:text-accent-blue"
							}
						>
							{link.label}
						</a>
					</li>
				))
			}
		</ul>
	</nav>
</header>
