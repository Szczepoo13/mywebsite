---
const links = [
	{ href: "/projects/", label: "Projects" },
	{ href: "/blog/", label: "Blog" },
];
---

<header class="bar border-b-2 border-border">
	<nav class="mx-auto flex max-w-4xl items-stretch justify-between px-4">
		<a href="/" class="block py-3 leading-tight">
			<span class="font-mono text-sm font-bold tracking-tight text-ink">SZCZEPAN GURGUL</span>
			<span class="block text-xs text-muted">[home]</span>
		</a>
		<ul class="flex text-sm">
			{
				links.map((link) => (
					<li class="flex">
						<a href={link.href} class="btn-blue flex items-center px-4 font-semibold">
							{link.label}
						</a>
					</li>
				))
			}
		</ul>
	</nav>
</header>
