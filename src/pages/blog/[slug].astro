---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
	// Nextrope-sourced posts live only as an expandable summary on /blog/ —
	// no local page, since the full post is on the company blog.
	const posts = (await getCollection("blog")).filter((post) => post.data.source === "personal");
	return posts.map((post) => ({
		params: { slug: post.id },
		props: { post },
	}));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout title={`${post.data.title} — Szczepan Gurgul`}>
	<article>
		<h1 class="text-xl font-bold tracking-tight">{post.data.title}</h1>
		<time datetime={post.data.date.toISOString()} class="mt-1 block text-xs text-muted">
			{post.data.date.toISOString().slice(0, 10)}
		</time>
		<div class="prose prose-sm mt-6 max-w-none">
			<Content />
		</div>
	</article>
</BaseLayout>
