---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
	const posts = await getCollection("blog");
	return posts.map((post) => ({
		params: { slug: post.id },
		props: { post },
	}));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout title={`${post.data.title} — Szczepan Gurgul`}>
	<article>
		<h1 class="text-xl font-semibold tracking-tight">{post.data.title}</h1>
		<time datetime={post.data.date.toISOString()} class="mt-1 block text-xs text-neutral-500">
			{post.data.date.toISOString().slice(0, 10)}
		</time>
		<div class="prose prose-sm prose-neutral mt-6 max-w-none">
			<Content />
		</div>
	</article>
</BaseLayout>
