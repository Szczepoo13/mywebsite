---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import PublicationCard from "../../components/PublicationCard.astro";

const publications = (await getCollection("publications")).sort(
	(a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
---

<BaseLayout title="Publications — Szczepan Gurgul">
	<h1 class="text-xl font-semibold tracking-tight">Publications</h1>
	<div class="mt-6 flex flex-col gap-3">
		{
			publications.map((publication) => (
				<PublicationCard
					title={publication.data.title}
					authors={publication.data.authors}
					venue={publication.data.venue}
					date={publication.data.date}
					url={publication.data.url}
				/>
			))
		}
	</div>
</BaseLayout>
