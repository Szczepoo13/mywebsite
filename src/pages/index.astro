---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import Badge from "../components/Badge.astro";

const publications = (await getCollection("publications")).sort(
	(a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

const stackCategories = [
	{
		label: "AI",
		items: ["llm agents", "tool calling", "rag", "mcp"],
	},
	{
		label: "Blockchain",
		items: [
			"ethereum",
			"smart contracts",
			"l1/l2",
			"foundry",
			"dex/amm",
			"zkp",
			"mev"
		],
	},
	{
		label: "Software Engineering",
		items: [
			"git",
			"tdd",
			"scrum",
			"rest apis",
			"linux",
			"sql",
			"k8s",
			"docker",
			"cloud",
			"grafana",
		],
	},
	{
		label: "Programming Languages",
		items: ["python", "typescript", "javascript", "bash", "solidity", "rust", "c++"],
	},
];

// TODO: replace with real Uniswap v4 hook incubator details.
const achievements = [
	{
		title: "BCOLN Challenge Award - Best Distributed dApp",
		description: "Won the BCOLN Challenge Hackathon (2024) with a Decentralized Sports Betting Platform, competing against 10 teams from across Zurich.",
	},
	{
		title: "Uniswap v4 Hook Incubator",
		description: "Selected for the Uniswap v4 Hooks Incubator (Atrium Academy), protocol engineering cohort focused on designing, implementing, and testing production-ready Uniswap v4 Hooks. Cohort starts in October 2026.",
	},
	{
		title: "Conference Presentations",
		description: "Presented research in person at BCK24 (Zürich, 2024) and BCK25 (Mumbai, 2025).",
	},
];
---

<BaseLayout title="Szczepan Gurgul" bgPattern="grid">
	<section class="card px-6 py-8">
		<h1 class="text-2xl font-bold tracking-tight">Szczepan Gurgul</h1>
		<p class="mt-1 text-sm text-muted">Software &amp; Blockchain Engineer</p>
		<p class="mt-6 max-w-2xl text-sm leading-relaxed">
			Software engineer with blockchain expertise and a background in distributed systems. I
			build secure, maintainable systems and tooling - from smart contracts and DeFi primitives
			(DEX/AMM) to performance-oriented infrastructure. Currently working as an AI × Blockchain
			Engineer @ Nextrope, building AI agent workflows for smart contract security analysis and
			EVM bytecode auditing.
		</p>
		<div class="mt-6 border-t border-border pt-4 text-sm">
			<p class="font-bold">Education</p>
			<p class="mt-1 text-muted">M.Sc. Informatics, University of Zürich — 2026 (magna cum laude)</p>
			<p class="mt-1 text-muted">
				B.Sc. Mechatronic Engineering, AGH University of Science and Technology — 2023
			</p>
		</div>
		<div class="mt-6 border-t border-border pt-4 text-sm">
			<p class="font-bold">Stack</p>
			<div class="mt-3 flex flex-col gap-3">
				{
					stackCategories.map((category) => (
						<div>
							<p class="text-xs font-semibold tracking-wide text-muted uppercase">
								{category.label}
							</p>
							<div class="mt-1.5 flex flex-wrap gap-2">
								{category.items.map((item) => (
									<Badge label={item} />
								))}
							</div>
						</div>
					))
				}
			</div>
		</div>
	</section>

	<section class="mt-6">
		<h2 class="text-xl font-bold tracking-tight">Achievements</h2>
		<div class="mt-4 flex flex-col gap-3">
			{
				achievements.map((achievement) => (
					<div class="card px-5 py-4">
						<h3 class="text-base font-bold tracking-tight">{achievement.title}</h3>
						<p class="mt-2 text-sm text-muted">{achievement.description}</p>
					</div>
				))
			}
		</div>
	</section>

	<section class="mt-6">
		<h2 class="text-xl font-bold tracking-tight">Publications</h2>
		<div class="mt-4 grid gap-2 sm:grid-cols-2">
			{
				publications.map((publication) => (
					<div class="card px-3 py-2 text-xs">
						<p class="text-base font-bold tracking-tight">
							{publication.data.url ? (
								<a
									href={publication.data.url}
									class="text-accent-blue hover:underline"
									target="_blank"
									rel="noreferrer"
								>
									{publication.data.title}
								</a>
							) : (
								publication.data.title
							)}
						</p>
						<p class="mt-1 text-muted">
							{publication.data.venue} · {publication.data.date.getFullYear()}
						</p>
						{publication.data.description && (
							<p class="mt-2 text-muted">{publication.data.description}</p>
						)}
						{publication.data.highlights && (
							<ul class="mt-2 list-disc space-y-2 pl-4 text-muted">
								{publication.data.highlights.map((point) => <li>{point}</li>)}
							</ul>
						)}
						{publication.data.tags.length > 0 && (
							<div class="mt-2 flex flex-wrap gap-1">
								{publication.data.tags.map((tag) => (
									<Badge label={tag} />
								))}
							</div>
						)}
					</div>
				))
			}
		</div>
	</section>
</BaseLayout>
