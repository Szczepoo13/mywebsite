---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import PublicationCard from "../components/PublicationCard.astro";

const publications = (await getCollection("publications")).sort(
	(a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
---

<BaseLayout title="Szczepan Gurgul">
	<section class="panel-raised px-6 py-8">
		<h1 class="text-2xl font-bold tracking-tight">Szczepan Gurgul</h1>
		<p class="mt-1 text-sm">Blockchain Researcher / Software Engineer</p>
		<!-- TODO: replace with real bio copy. -->
		<p class="mt-6 max-w-2xl text-sm leading-relaxed">
			I research blockchain protocols and build software at the intersection of distributed
			systems and applied cryptography.
		</p>
		<!-- TODO: replace with real education details. -->
		<div class="mt-6 border-t-2 border-bevel pt-4 text-sm">
			<p class="font-bold">Education</p>
			<p class="mt-1">Ipsum Institute of Technology, M.Sc. Lorem Studies — 2019</p>
		</div>
	</section>

	<section class="mt-6">
		<h2 class="text-xl font-bold tracking-tight">Publications</h2>
		<div class="mt-4 flex flex-col gap-3">
			{
				publications.map((publication) => (
					<PublicationCard
						title={publication.data.title}
						authors={publication.data.authors}
						venue={publication.data.venue}
						date={publication.data.date}
						url={publication.data.url}
					/>
				))
			}
		</div>
	</section>
</BaseLayout>
