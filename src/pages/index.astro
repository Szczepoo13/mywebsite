---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import Badge from "../components/Badge.astro";

const publications = (await getCollection("publications")).sort(
	(a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

const stack = [
	"Ξ Ethereum",
	"Solidity",
	"Rust",
	"TypeScript",
	"Python",
	"Docker",
	"Kubernetes",
	"PostgreSQL",
];

// TODO: replace with real Uniswap v4 hook incubator details.
const achievements = [
	{
		title: "BCOLN Challenge Award — Best Distributed dApp",
		description: "Won for the Decentralized Sports Betting Platform, 2024.",
	},
	{
		title: "Uniswap v4 Hook Incubator",
		description: "TODO: add details.",
	},
	{
		title: "Conference Presentations",
		description: "Presented research in person at BCK24 (Zürich, 2024) and BCK25 (Mumbai, 2025).",
	},
];
---

<BaseLayout title="Szczepan Gurgul" bgPattern="grid">
	<section class="card px-6 py-8">
		<h1 class="text-2xl font-bold tracking-tight">Szczepan Gurgul</h1>
		<p class="mt-1 text-sm text-muted">Software &amp; Blockchain Engineer</p>
		<p class="mt-6 max-w-2xl text-sm leading-relaxed">
			Software engineer with blockchain expertise and a background in distributed systems. I
			build secure, maintainable systems and tooling — from smart contracts and DeFi primitives
			(DEX/AMM) to performance-oriented infrastructure — and have co-authored two research
			papers on blockchain technologies.
		</p>
		<div class="mt-6 border-t border-border pt-4 text-sm">
			<p class="font-bold">Education</p>
			<p class="mt-1 text-muted">M.Sc. Informatics, University of Zürich — 2026 (magna cum laude)</p>
			<p class="mt-1 text-muted">
				B.Sc. Mechatronic Engineering, AGH University of Science and Technology — 2023
			</p>
		</div>
		<div class="mt-6 border-t border-border pt-4 text-sm">
			<p class="font-bold">Stack</p>
			<div class="mt-2 flex flex-wrap gap-2">
				{stack.map((item) => <Badge label={item} />)}
			</div>
		</div>
	</section>

	<section class="mt-6">
		<h2 class="text-xl font-bold tracking-tight">Achievements</h2>
		<div class="mt-4 flex flex-col gap-3">
			{
				achievements.map((achievement) => (
					<div class="card px-5 py-4">
						<h3 class="text-base font-bold tracking-tight">{achievement.title}</h3>
						<p class="mt-2 text-sm text-muted">{achievement.description}</p>
					</div>
				))
			}
		</div>

		<div class="mt-6">
			<h3 class="text-sm font-bold tracking-tight text-muted">Publications</h3>
			<div class="mt-2 grid gap-2 sm:grid-cols-2">
				{
					publications.map((publication) => (
						<div class="card px-3 py-2 text-xs">
							<p class="font-bold">
								{publication.data.url ? (
									<a
										href={publication.data.url}
										class="text-accent-blue hover:underline"
										target="_blank"
										rel="noreferrer"
									>
										{publication.data.title}
									</a>
								) : (
									publication.data.title
								)}
							</p>
							<p class="mt-1 text-muted">
								{publication.data.venue} · {publication.data.date.getFullYear()}
							</p>
						</div>
					))
				}
			</div>
		</div>
	</section>
</BaseLayout>
