---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Badge from "../../components/Badge.astro";

export async function getStaticPaths() {
	const projects = await getCollection("projects");
	return projects.map((project) => ({
		params: { slug: project.id },
		props: { project },
	}));
}

const { project } = Astro.props;
const { Content } = await render(project);
---

<BaseLayout title={`${project.data.title} — Szczepan Gurgul`}>
	<article class="card px-6 py-6">
		<h1 class="text-xl font-bold tracking-tight">{project.data.title}</h1>
		{
			project.data.researchPaper && (
				<p class="mt-1 text-xs font-semibold text-gold">
					Part of research paper:{" "}
					{project.data.researchPaperUrl ? (
						<a href={project.data.researchPaperUrl} target="_blank" rel="noreferrer" class="hover:underline">
							{project.data.researchPaper}
						</a>
					) : (
						<a href={`${import.meta.env.BASE_URL}projects/`} class="hover:underline">
							{project.data.researchPaper}
						</a>
					)}
				</p>
			)
		}
		{
			project.data.tags.length > 0 && (
				<div class="mt-3 flex flex-wrap gap-2">
					{project.data.tags.map((tag) => (
						<Badge label={tag} />
					))}
				</div>
			)
		}
		<div class="mt-3 flex gap-2 text-xs">
			<a href={`${import.meta.env.BASE_URL}projects/`} class="btn-blue btn-3d px-3 py-1 font-semibold">
				← Back to Projects
			</a>
			{project.data.repo && (
				<a
					href={project.data.repo}
					class="btn-blue btn-3d px-3 py-1 font-semibold"
					target="_blank"
					rel="noreferrer"
				>
					Repo
				</a>
			)}
			{project.data.url && (
				<a
					href={project.data.url}
					class="btn-blue btn-3d px-3 py-1 font-semibold"
					target="_blank"
					rel="noreferrer"
				>
					Live
				</a>
			)}
		</div>
		<div class="prose prose-sm mt-6 max-w-none">
			<Content />
		</div>
	</article>
</BaseLayout>
