---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Thanks - Szczepan Gurgul">
	<div class="card mt-6 px-6 py-8 text-center">
		<h1 class="text-xl font-bold tracking-tight">Thanks for reaching out</h1>
		<p class="mt-2 text-sm text-muted">Your message has been sent. I'll get back to you soon.</p>
		<a
			href={`${import.meta.env.BASE_URL}`}
			class="btn-blue btn-3d mt-6 inline-block px-4 py-2 text-sm font-semibold"
		>
			Back to home
		</a>
	</div>
</BaseLayout>
